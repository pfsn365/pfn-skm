{include file="./styles.tpl"}
{include file="./js.tpl"}

<template id="feed-template">
  <a href="#" target="_blank" class="single-feed">
    <img src="" alt="Feed Image" class="feed-image">
    <div class="feed-data-container">
      <div class="feed-title"></div>
      <span class="feed-time"></span>
    </div>
  </a>
</template>

<template id="header-template">
  <div class="header-container">
    <div class="header-bar"></div>
    <div class="header-text"></div>
  </div>
</template>

<template id="load-more-template">
  <button class="load-more-feeds-btn">View More</button>
</template>
