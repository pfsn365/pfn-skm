{include file="./styles.tpl"}

<div class="milestones-container">
  <span class="milestones-text dashboard-widget-heading">Milestones</span>
  <div class="milestones-data-holder">
    <div class="milestone day-drafts">
      <div class="header-text">
        <span>Most Drafts in a Day</span>
      </div>
      <div class="milestone-data">
        <span class="date">31st Jan, 2025</span>
        <div class="vs-container">
          <div class="user-data">
            <span class="draft-count">10</span>
            <span class="user-text">You</span>
          </div>
          <div class="separator"></div>
          <div class="highest-data">
            <span class="draft-count">66</span>
            <span class="highest-text">Highest</span>
          </div>
        </div>
      </div>
    </div>
    <div class="milestone week-drafts">
      <div class="header-text">
        <span>Most Drafts in a Week</span>
      </div>
      <div class="milestone-data">
        <span class="date">Feb 2 - Feb 8, 2025</span>
        <div class="vs-container">
          <div class="user-data">
            <span class="draft-count">190</span>
            <span class="user-text">You</span>
          </div>
          <div class="separator"></div>
          <div class="highest-data">
            <span class="draft-count">687</span>
            <span class="highest-text">Highest</span>
          </div>
        </div>
      </div>
    </div>
    <div class="milestone month-drafts">
      <div class="header-text">
        <span>Most Drafts in a Month</span>
      </div>
      <div class="milestone-data">
        <span class="date">Feb, 2025</span>
        <div class="vs-container">
          <div class="user-data">
            <span class="draft-count">540</span>
            <span class="user-text">You</span>
          </div>
          <div class="separator"></div>
          <div class="highest-data">
            <span class="draft-count">956</span>
            <span class="highest-text">Highest</span>
          </div>
        </div>
      </div>
    </div>
    <div class="milestone most-players-drafts">
      <div class="header-text">
        <span>Most Players Drafted in a Mock</span>
      </div>
      <div class="milestone-data">
        <span class="date">30th Jan, 2025</span>
        <div class="vs-container">
          <div class="user-data">
            <span class="draft-count">30</span>
            <span class="user-text">You</span>
          </div>
          <div class="separator"></div>
          <div class="highest-data">
            <span class="draft-count">257</span>
            <span class="highest-text">Highest</span>
          </div>
        </div>
      </div>
    </div>
    <div class="milestone most-trades-drafts">
      <div class="header-text">
        <span>Most Successful Trades in a Draft</span>
      </div>
      <div class="milestone-data">
        <span class="date">30th Jan, 2025</span>
        <div class="vs-container">
          <div class="user-data">
            <span class="draft-count">12</span>
            <span class="user-text">You</span>
          </div>
          <div class="separator"></div>
          <div class="highest-data">
            <span class="draft-count">27</span>
            <span class="highest-text">Highest</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{include file="./js.tpl"}
