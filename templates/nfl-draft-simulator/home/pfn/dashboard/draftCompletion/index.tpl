{include file="./styles.tpl"}

<div class="draft-completion-charts-container">
  <span class="draft-completion-text dashboard-widget-heading">Draft Completion</span>
  <div class="draft-completion-charts-holder">
    <div class="user-chart-container">
      <div class="user-draft-participation-chart">
        <div class="user-draft-participation-subchart">
          <span class="chart-percentage-text">50%</span>
        </div>
      </div>
      <span class="user-text">You</span>
    </div>
    <div class="average-chart-container">
      <div class="average-draft-participation-chart">
        <div class="average-draft-participation-subchart">
          <span class="chart-percentage-text">61%</span>
        </div>
      </div>
      <span class="average-text">Avg</span>
    </div>
  </div>
  <div class="draft-completion-count-container">
    <div class="participation">
      <span class="count">2512 : </span>
      <span class="participated-text">Participated</span>
    </div>
    <div class="completion">
      <span class="count">1256 : </span>
      <span class="completion-text">Completed</span>
    </div>
  </div>
</div>

